--------------------------------------------------
-- CREATE HITBOX
--------------------------------------------------
local function createHitbox(mob)
    if mob:FindFirstChild("BrainrotHitbox") then return end
    local hrpMob = mob:FindFirstChild("HumanoidRootPart")
    if not hrpMob then return end

    local hitbox = Instance.new("Part")
    hitbox.Name = "BrainrotHitbox"
    hitbox.Size = HitboxSize
    hitbox.Transparency = 0.5
    hitbox.Color = Color3.fromRGB(255,0,0)
    hitbox.Anchored = true
    hitbox.CanCollide = false
    hitbox.Parent = mob

    RunService.Heartbeat:Connect(function()
        if hitbox and hrpMob then
            hitbox.CFrame = hrpMob.CFrame
        end
    end)

    hitbox.Touched:Connect(function(hit)
        if character and hit.Parent == character then
            pcall(function()
                HitMob:FireServer(mob,1000000)
            end)
        end
    end)
end

--------------------------------------------------
-- PROCESS MOBS
--------------------------------------------------
local function processMobs()
    if not mobsFolder or not hrp then return end
    for _,mob in pairs(mobsFolder:GetChildren()) do
        if mob:IsA("Model") then
            createHitbox(mob)
            local hrpMob = mob:FindFirstChild("HumanoidRootPart")
            local humanoid = mob:FindFirstChildOfClass("Humanoid")
            if hrpMob then
                hrpMob.CFrame = hrp.CFrame * CFrame.new(0,0,-5)
            end
            if humanoid then
                humanoid.Health = 0
            end
        end
    end
end

