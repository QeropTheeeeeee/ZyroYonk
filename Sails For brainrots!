-- Auto Collect Selection for Zone13
local TweenService = game:GetService("TweenService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local hrp
local function getHRP()
	local char = player.Character or player.CharacterAdded:Wait()
	hrp = char:WaitForChild("HumanoidRootPart")
	return hrp
end

-- Folder with Zone13 objects
local objectsFolder = workspace.Zones.Zone13.Objects
local teleportPath = workspace.Map.Start.StartIsland

-- Selected object for auto-collect
local selectedObjectName = nil
local autoCollect = false
local collecting = false

-- Tween function
local function tweenTo(part)
	local hrp = getHRP()
	local tween = TweenService:Create(
		hrp,
		TweenInfo.new(1.2, Enum.EasingStyle.Linear),
		{CFrame = part.CFrame + Vector3.new(0,3,0)}
	)
	tween:Play()
	tween.Completed:Wait()
end

-- Collect function
local function collectObject(obj)
	if collecting or not autoCollect then return end
	collecting = true

	local part = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart", true)

	if part then
		tweenTo(part)
		task.wait(0.2)

		-- Hold E
		VirtualInputManager:SendKeyEvent(true,"E",false,game)
		task.wait(0.5)
		VirtualInputManager:SendKeyEvent(false,"E",false,game)

		task.wait(0.2)

		-- Teleport back
		getHRP().CFrame = teleportPath.CFrame + Vector3.new(0,3,0)
	end

	collecting = false
end

-- Scan for selectable objects
local objectNames = {}
for _, obj in pairs(objectsFolder:GetChildren()) do
	table.insert(objectNames, obj.Name)
end

