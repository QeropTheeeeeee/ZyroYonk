-- WEBHOOK SENDER
local function sendWebhook(data)

    if not request then
        warn("Executor does not support HTTP requests")
        return
    end

    request({
        Url = webhook,
        Method = "POST",
        Headers = {["Content-Type"]="application/json"},
        Body = HttpService:JSONEncode(data)
    })
end


