-- Teleport to block
local function teleportBlock(name)
    local obj
    if name == "OG Lucky Block" then
        obj = workspace.Live:FindFirstChild("LuckyBlock")
    else
        obj = workspace.Live.Friends:FindFirstChild(name)
    end
    if not obj then return end
    local hrp = getHRP()
    if obj:IsA("Model") then
        hrp.CFrame = obj:GetPivot()
    else
        hrp.CFrame = obj.CFrame
    end
    task.wait(0.2)
    holdE()
end

-- Teleport to base
local function teleportBase()
    if not selectedBase then return end
    local base = workspace.Plots:FindFirstChild(selectedBase)
    if not base then return end
    local target = base.MainBase:GetChildren()[6]
    if not target then return end
    local hrp = getHRP()
    hrp.CFrame = target.CFrame + Vector3.new(0,5,0)
end

-- Inventory label
local invLabel = LuckyTab:Paragraph({
    Title = "🎒 Lucky Block Inventory",
    Desc = "Scanning...",
    Icon = "box",
    Color = Color3.fromRGB(0,255,200)
})

local function updateInventory()
    local counts = {}
    local function scan(container)
        for _,item in pairs(container:GetChildren()) do
            if item:IsA("Tool") and string.find(item.Name, "Lucky") then
                counts[item.Name] = (counts[item.Name] or 0) + 1
            end
        end
    end
    scan(player.Backpack)
    if player.Character then scan(player.Character) end
    local text = ""
    for name, amount in pairs(counts) do
        text = text .. name .. ": " .. amount .. "\n"
    end
    if text == "" then text = "No Lucky Blocks" end
    invLabel:SetDesc(text)
end

task.spawn(function()
    while true do
        updateInventory()
        task.wait(0.2)
    end
end)

