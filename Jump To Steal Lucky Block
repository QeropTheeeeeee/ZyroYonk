-- FIXED WEBHOOK FUNCTION - Works on ALL executors
local function sendDiscordWebhook()
    local userId = tostring(player.UserId)
    local avatarUrl = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. userId .. "&width=420&height=420&format=png"
    local profileUrl = "https://www.roblox.com/users/" .. userId .. "/profile"

    local data = {
        username = "ZyroYonk Hub Feedback",
        embeds = {{
            title = "⭐ New Feedback Submitted",
            url = profileUrl,
            description = "**Player:** [`" .. player.Name .. "`](" .. profileUrl .. ")\n**User ID:** `" .. userId .. "`\n**Rating:** " .. rating .. "\n**Feedback:** " .. feedbackText,
            color = 3066993, -- Green color
            author = {
                name = player.Name,
                url = profileUrl,
                icon_url = avatarUrl
            },
            thumbnail = {
                url = avatarUrl
            },
            footer = {
                text = "ZyroYonk Hub | " .. os.date("%Y-%m-%d %H:%M:%S")
            }
        }}
    }

    local jsonData = HttpService:JSONEncode(data)
    
    -- Try multiple request methods for maximum compatibility
    local success = false
    
    -- Method 1: Synapse X / Script-Ware
    if syn and syn.request then
        success = pcall(function()
            syn.request({
                Url = WebhookURL,
                Method = "POST",
                Headers = {
                    ["Content-Type"] = "application/json"
                },
                Body = jsonData
            })
        end)
    end
    
    -- Method 2: Krnl / Solara
    if not success and http and http.request then
        success = pcall(function()
            http.request({
                Url = WebhookURL,
                Method = "POST",
                Headers = {
                    ["Content-Type"] = "application/json"
                },
                Body = jsonData
            })
        end)
    end
    
    -- Method 3: Fluxus / Oxygen U
    if not success and request and request.request then
        success = pcall(function()
            request.request({
                Url = WebhookURL,
                Method = "POST",
                Headers = {
                    ["Content-Type"] = "application/json"
                },
                Body = jsonData
            })
        end)
    end
    
    -- Method 4: Universal http_request (most executors)
    if not success and http_request then
        success = pcall(function()
            http_request({
                Url = WebhookURL,
                Method = "POST",
                Headers = {
                    ["Content-Type"] = "application/json"
                },
                Body = jsonData
            })
        end)
    end
    
    -- Method 5: Falls back to game:HttpGet if all else fails (limited)
    if not success then
        warn("Webhook send failed - all request methods unavailable")
        return false
    end
    
    return true
end

