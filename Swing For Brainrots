local function teleportToZone(zone)
	if zone:IsA("BasePart") then
		getHRP().CFrame = zone.CFrame + Vector3.new(0,3,0)
	elseif zone:IsA("Model") and zone.PrimaryPart then
		getHRP().CFrame = zone.PrimaryPart.CFrame + Vector3.new(0,3,0)
	end
end

