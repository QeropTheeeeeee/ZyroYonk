--------------------------------------------------
-- AUTO COLLECT SLOTS 1-10
--------------------------------------------------
local AutoCollectSlots = false

SpawnTab:Toggle({
    Title = "Auto Collect",
    Default = false,
    Callback = function(state)
        AutoCollectSlots = state

        task.spawn(function()
            while AutoCollectSlots do
                for slot = 1, 10 do
                    local args = {slot}
                    game:GetService("ReplicatedStorage")
                        :WaitForChild("Remotes")
                        :WaitForChild("CollectSlot")
                        :FireServer(unpack(args))
                end
                task.wait(0.3) -- adjust speed if needed
            end
        end)
    end
})

--------------------------------------------------
-- AUTO REBIRTH
--------------------------------------------------
local AutoRebirth = false

SpawnTab:Toggle({
    Title = "Auto Rebirth",
    Default = false,
    Callback = function(state)
        AutoRebirth = state

        task.spawn(function()
            while AutoRebirth do
                game:GetService("ReplicatedStorage")
                    :WaitForChild("Remotes")
                    :WaitForChild("Rebirth")
                    :FireServer()

                task.wait(0.5) -- adjust speed if needed
            end
        end)
    end
})

