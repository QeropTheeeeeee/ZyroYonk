--------------------------------------------------
-- VARIABLES
--------------------------------------------------
local SelectedOpenPacks = {}
local SelectedBuyPacks = {}

local AutoOpen = false
local AutoBuy = false

--------------------------------------------------
-- MULTI SELECT PACKS TO OPEN
--------------------------------------------------
SpawnTab:Dropdown({
    Title = "Select Packs To Buy",
    Multi = true,
    Values = {
        "Bronze","Silver","Gold",
        "Platinum","Diamond","Toxic",
        "Shadow","Infernal","Corrupted",
        "Cosmic","Eclipse","Hades",
        "Heaven","Chaos","Ordian",
        "Alpha","Omega"
    },
    Default = {},
    Callback = function(v)
        SelectedOpenPacks = v
    end
})

--------------------------------------------------
-- AUTO OPEN PACK
--------------------------------------------------
SpawnTab:Toggle({
    Title = "Auto Open Pack",
    Default = false,
    Callback = function(state)
        AutoOpen = state

        task.spawn(function()
            while AutoOpen do
                for _,pack in pairs(SelectedOpenPacks) do
                    ReplicatedStorage.Remotes.OpenPack:FireServer(pack)
                end
                task.wait(0.2)
            end
        end)
    end
})

--------------------------------------------------
-- MULTI SELECT PACKS TO BUY
--------------------------------------------------
