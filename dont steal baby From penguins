-- Collection counter
local collectionCount = 0
local counterParagraph = SpawnTab:Paragraph({
    Title = "📊 Collection Stats",
    Desc = "You have collected 0 times.",
    Icon = "check-circle"
})
local function updateCounter()
    counterParagraph:SetDesc("You have collected " .. collectionCount .. " times.")
end

-- Function to collect
local function collectAtSpawn(baseNum, plotPart)
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")

    -- Teleport to plot
    if plotPart then
        hrp.CFrame = plotPart.CFrame + Vector3.new(0,5,0)
        task.wait(0.2)
    end

    -- Teleport to spawn
    local spawnPoint = workspace.Map.Bases[baseNum].Stands["5"].SpawnPoint
    if spawnPoint then
        hrp.CFrame = spawnPoint.CFrame
        task.wait(0.2)

        -- Press E
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        task.wait(0.6)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)

        -- Increment counter
        collectionCount = collectionCount + 1
        updateCounter()
    else
        warn("SpawnPoint "..baseNum.." not found!")
    end
end

-- Toggle for auto-collect
local autoCollect = false

SpawnTab:Toggle({
    Title = "🔁 Auto Collect Selected Plot",
    Default = false,
    Icon = "play",
    Callback = function(state)
        autoCollect = state

        if autoCollect then
            -- Validate selections
            if not selectedSpawn then
                WindUI:Notify({
                    Title = "⚠ Missing Spawn Base",
                    Content = "You need to select a spawn base first!",
                    Duration = 4,
                    Icon = "alert-circle"
                })
                autoCollect = false
                return
            end

            if not selectedPlotIndex then
                WindUI:Notify({
                    Title = "⚠ Missing Plot",
                    Content = "You need to select a plot first!",
                    Duration = 4,
                    Icon = "alert-circle"
                })
                autoCollect = false
                return
            end

            task.spawn(function()
                while autoCollect do
                    local plotPart = workspace.Plots:GetChildren()[selectedPlotIndex]
                    if plotPart and plotPart:FindFirstChild("TeleportPart") then
                        collectAtSpawn(selectedSpawn, plotPart.TeleportPart)
                    else
                        warn("Selected plot's TeleportPart not found!")
                    end
                    task.wait(1)
                end
            end)
        end
    end
})

