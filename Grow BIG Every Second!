local TeleportEnabled = false

local function getHitbox()
    local folder = workspace:FindFirstChild("WinGivingButtons")
    if not folder then return nil end

    local children = folder:GetChildren()
    if #children < 18 then return nil end

    local button = children[18]
    if button then
        return button:FindFirstChild("Hitbox")
    end
end

GUI:CreateToggle({
    parent = main,
    text = "Teleport to Win Button",
    state = false,
    callback = function(value)

        TeleportEnabled = value

        if value then
            task.spawn(function()
                while TeleportEnabled do
                    local hitbox = getHitbox()

                    if hrp and hitbox then
                        hrp.CFrame = hitbox.CFrame + Vector3.new(0,3,0)
                    end

                    task.wait(0.1)
                end
            end)
        end

    end
})


