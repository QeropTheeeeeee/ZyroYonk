local keysDown = {}

-- Setup character
local function setupCharacter(char)
	character = char
	hrp = character:WaitForChild("HumanoidRootPart")
	pos = hrp.CFrame
	hrp.Anchored = fly
end

setupCharacter(player.Character or player.CharacterAdded:Wait())

player.CharacterAdded:Connect(function(char)
	setupCharacter(char)
end)

-- Key tracking
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.UserInputType == Enum.UserInputType.Keyboard then
		keysDown[input.KeyCode] = true
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Keyboard then
		keysDown[input.KeyCode] = nil
	end
end)

-- Movement update
RunService.RenderStepped:Connect(function(deltaTime)
	if not fly or not hrp then return end

	local moveVector = Vector3.zero
	
	if keysDown[Enum.KeyCode.W] then moveVector += Vector3.new(0,0,-1) end
	if keysDown[Enum.KeyCode.S] then moveVector += Vector3.new(0,0,1) end
	if keysDown[Enum.KeyCode.A] then moveVector += Vector3.new(-1,0,0) end
	if keysDown[Enum.KeyCode.D] then moveVector += Vector3.new(1,0,0) end
	if keysDown[Enum.KeyCode.Space] then moveVector += Vector3.new(0,1,0) end
	if keysDown[Enum.KeyCode.LeftShift] then moveVector += Vector3.new(0,-1,0) end

	if moveVector.Magnitude > 0 then
		local camCF = CFrame.new(Vector3.zero, camera.CFrame.LookVector)
		local direction = camCF:VectorToWorldSpace(moveVector).Unit
		pos += direction * speed * deltaTime
	end
end)

-- Apply position
RunService.Heartbeat:Connect(function()
	if fly and hrp then
		hrp.CFrame = CFrame.new(pos.Position) * CFrame.Angles(hrp.CFrame:ToEulerAnglesXYZ())
	end
end)


